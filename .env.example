# AWS Configuration
# IMPORTANT: Get your actual AWS_SECRET_KEY from AWS IAM console
# DO NOT commit real keys - this file is for development reference only
AWS_SECRET_KEY=your_aws_secret_key_here

# Example AWS Key format:
# AWS_SECRET_KEY=AKIAIOSFODNN7EXAMPLE

# Logging configuration
LOG_LEVEL=INFO
LOG_FILE=app.log

# Environment
ENVIRONMENT=development

# Database credentials (example)
# DATABASE_URL=postgres://username:password@localhost:5432/dbname
# DATABASE_PASSWORD=your_secure_password_here

# API tokens (example)
# API_TOKEN=sk_test_1234567890abcdefghijk
# STRIPE_KEY=sk_test_123456

# Development flags
DEBUG=True
TESTING=False

# SECURITY WARNING:
# This .env.example file is safe to commit to version control
# BUT your .env file with ACTUAL secrets should NEVER be committed
# Make sure .env is in your .gitignore!
